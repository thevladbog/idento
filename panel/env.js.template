// AGENT_URL: the local print agent runs on the operator's own machine, not
// the server serving this panel build — if the deploy pipeline leaves
// PUBLIC_AGENT_URL unset, this substitutes to an empty string and
// getAgentBaseUrl() (panel/src/shared/api/http.ts) falls back to
// "http://localhost:12345", the agent's documented default port.
window.__ENV__ = { API_URL: "${PUBLIC_API_URL}", AGENT_URL: "${PUBLIC_AGENT_URL}" };
