<?xml version="1.0" encoding="utf-8"?>
<!--
  Release / all non-debug builds: cleartext HTTP is never permitted.
  The debug variant overrides this file with src/debug/res/xml/network_security_config.xml,
  which additionally allows cleartext to local dev servers only.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
