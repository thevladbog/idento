# Idento on-prem — copy this file to .env and fill in the values marked
# REQUIRED. install.sh does this for you and auto-generates the two secrets;
# run it before editing this file by hand.

# --- Postgres ---
POSTGRES_USER=idento
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=idento_db

# --- Backend ---
# Auto-generated by install.sh — a long random string, do not reuse across installs.
JWT_SECRET=change-me

# Comma-separated list of origins allowed to call the API from a browser.
# Must include the URL you'll actually open the web UI at.
CORS_ALLOWED_ORIGINS=http://your-host

# REQUIRED: the first admin account, created automatically on first start.
# Only used once — on an empty database. Ignored on every later restart.
IDENTO_ADMIN_EMAIL=admin@example.com
IDENTO_ADMIN_PASSWORD=change-me

# Optional — defaults to "My Organization" if left unset.
# IDENTO_ORG_NAME=My Organization

# --- Web ---
# REQUIRED: the URL your browser will use to reach the backend API.
# Must be reachable from wherever you open the web UI — e.g.
# http://your-server-ip:8008 or https://api.your-domain.com.
PUBLIC_API_URL=http://your-host:8008

# --- Release ---
# The tarball version you downloaded, e.g. v1.2.3. Defaults to "latest" if
# unset — pin this to the version you tested against for predictable upgrades.
# VERSION=v1.2.3
